model PriceMapping {
  id            Int             @id @default(autoincrement())
  lensPrice_id  Int
  lensPrice     LensPriceMaster @relation(fields: [lensPrice_id], references: [id])
  customer_id   Int
  customer      Customer        @relation(fields: [customer_id], references: [id])
  discountRate  Float           @default(0) // Percentage discount for this customer on this lens price
  discountPrice Float           @default(0) // Calculated discount price after applying discount rate
  createdAt     DateTime        @default(now())
  createdBy     Int
  updatedAt     DateTime        @updatedAt
  updatedBy     Int?
  createdByUser User            @relation("priceMappingCreatedBy", fields: [createdBy], references: [id])
  updatedByUser User?           @relation("priceMappingUpdatedBy", fields: [updatedBy], references: [id])
}

model SaleOrder {
  id                Int                 @id @default(autoincrement())
  orderNo           String              @unique // e.g., SO-2025-001
  customerId        Int
  customer          Customer            @relation(fields: [customerId], references: [id])
  status            SaleOrderStatus     @default(DRAFT)
  // Basic order information
  customerRefNo     String? // Customer reference number
  orderDate         DateTime            @default(now())
  type              String? // "Normal Processing", "Rush Processing", "Premium Processing"
  deliverySchedule  DateTime?
  remark            String?
  itemRefNo         String?
  freeLens          Boolean             @default(false)
  urgentOrder       Boolean             @default(false)
  freeFitting       Boolean             @default(false)
  // Offer information
  offer_id          Int?                // Applied offer (if any)
  offer             LensOffers?         @relation(fields: [offer_id], references: [id])
  // Lens details
  lens_id           Int?
  category_id       Int? // "Single Vision", "BiFocal", "Progressive", "Reading"
  Type_id           Int? // "Glass", "Plastic", "Polycarbonate", "Trivex"
  dia_id            Int?
  fitting_id        Int? // "Standard", "Premium", "Custom"
  material_id       Int? // Material type reference
  coating_id        Int? // "Anti-Reflection", "UV Protection", "Blue Light", "Scratch Resistant"
  tinting_id        Int? // "Clear", "Light Brown", "Dark Brown", "Gray", "Green"
  lensProduct       LensProductMaster?  @relation(fields: [lens_id], references: [id])
  category          LensCategoryMaster? @relation(fields: [category_id], references: [id])
  lensType          LensTypeMaster?     @relation(fields: [Type_id], references: [id])
  dia               LensDiaMaster?      @relation(fields: [dia_id], references: [id])
  fitting           LensFittingMaster?  @relation(fields: [fitting_id], references: [id])
  material          LensMaterialMaster? @relation(fields: [material_id], references: [id])
  coating           LensCoatingMaster?  @relation(fields: [coating_id], references: [id])
  tinting           LensTintingMaster?  @relation(fields: [tinting_id], references: [id])
  // Eye selection
  rightEye          Boolean             @default(false)
  leftEye           Boolean             @default(false)
  // Right eye specifications
  rightSpherical    String?
  rightCylindrical  String?
  rightAxis         String?
  rightAdd          String?
  rightDia          String?
  // rightBase, rightBaseSize, rightBled removed
  // Left eye specifications
  leftSpherical     String?
  leftCylindrical   String?
  leftAxis          String?
  leftAdd           String?
  leftDia           String?
  // leftBase, leftBaseSize, leftBled removed
  // Dispatch information
  dispatchStatus    String?             @default("Pending") // "Pending", "Assigned", "In Transit", "Delivered"
  assignedPerson_id Int?
  dispatchId        String?
  estimatedDate     DateTime?
  estimatedTime     String?
  actualDate        DateTime?
  actualTime        String?
  dispatchNotes     String?
  deliverySignature String?           // Base64 PNG — customer signature captured on delivery

  // Billing information
  lensPrice       Float           @default(0)
  rightEyeExtra   Float           @default(0)
  leftEyeExtra    Float           @default(0)
  fittingPrice    Float           @default(0)
  tintingPrice    Float           @default(0)
  discount        Float           @default(0) // Percentage discount
  additionalPrice Json? // For any additional charges
  // Relations
  items           SaleOrderItem[]
  invoice         Invoice?        @relation(fields: [invoiceId], references: [id])
  invoiceId       Int?
  purchaseOrders  PurchaseOrder[]
  dispatch        DispatchCopy?   @relation(fields: [dispatchCopyId], references: [id])
  dispatchCopyId  Int?
  // Default fields
  activeStatus    Boolean         @default(true)
  deleteStatus    Boolean         @default(false)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  createdBy       Int
  updatedBy       Int?
  createdByUser   User            @relation("saleOrderCreatedBy", fields: [createdBy], references: [id])
  updatedByUser   User?           @relation("saleOrderUpdatedBy", fields: [updatedBy], references: [id])
  assignedPerson  User?           @relation("saleOrderAssignedPerson", fields: [assignedPerson_id], references: [id])
  inventoryItems  InventoryItem[]
  inventoryTransactions InventoryTransaction[] @relation("inventorySaleTransactions")
  // Parent / child relationship (Close & Create SO)
  parentId          Int?
  parent            SaleOrder?  @relation("SaleOrderChildren", fields: [parentId], references: [id])
  children          SaleOrder[] @relation("SaleOrderChildren")
}

model LocationMaster {
  id            Int          @id @default(autoincrement())
  name          String
  location_code String       @unique
  description   String?
  activeStatus  Boolean      @default(true)
  deleteStatus  Boolean      @default(false)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  createdBy     Int
  updatedBy     Int?
  // Relationship Fields
  createdByUser User         @relation("locationUserCreate", fields: [createdBy], references: [id])
  updatedByUser User?        @relation("locationUserUpdate", fields: [updatedBy], references: [id])
  // Relationship Tables
  trays         TrayMaster[]
  inventoryItems InventoryItem[]
  inventoryStock InventoryStock[]
  inventoryAlerts InventoryAlert[]
  inventoryFromTransactions InventoryTransaction[] @relation("inventoryFromLocation")
  inventoryToTransactions InventoryTransaction[] @relation("inventoryToLocation")
}

model TrayMaster {
  id            Int             @id @default(autoincrement())
  name          String
  tray_code     String          @unique
  description   String?
  capacity      Int?
  location_id   Int?
  activeStatus  Boolean         @default(true)
  deleteStatus  Boolean         @default(false)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  createdBy     Int
  updatedBy     Int?
  // Relationship Fields
  location      LocationMaster? @relation(fields: [location_id], references: [id])
  createdByUser User            @relation("trayUserCreate", fields: [createdBy], references: [id])
  updatedByUser User?           @relation("trayUserUpdate", fields: [updatedBy], references: [id])
  // Relationship Tables
  inventoryItems InventoryItem[]
  inventoryStock InventoryStock[]
  inventoryFromTransactions InventoryTransaction[] @relation("inventoryFromTray")
  inventoryToTransactions InventoryTransaction[] @relation("inventoryToTray")
}

// ============================================
// INVENTORY MODULE
// ============================================

enum InventoryTransactionType {
  INWARD_PO          // Purchase Order Inward
  INWARD_DIRECT      // Direct Inward (without PO)
  OUTWARD_SALE       // Sale Order Outward
  OUTWARD_RETURN     // Return to Vendor
  TRANSFER           // Inter-location/tray transfer
  ADJUSTMENT         // Stock adjustment (+ or -)
  DAMAGE             // Damaged stock write-off
}

enum InventoryItemStatus {
  AVAILABLE          // Ready for sale
  RESERVED           // Reserved for sale order
  IN_PRODUCTION      // Being processed
  DAMAGED            // Damaged/unusable
  RETURNED           // Returned by customer
  QUALITY_CHECK      // Under quality inspection
}

// Main inventory table to track individual lens items
model InventoryItem {
  id                    Int                      @id @default(autoincrement())
  batchNo               String?                  // Batch number from vendor
  serialNo              String?                  // Individual serial number if applicable
  
  // Product Details
  lens_id               Int
  lensProduct           LensProductMaster        @relation(fields: [lens_id], references: [id])
  category_id           Int?
  category              LensCategoryMaster?      @relation(fields: [category_id], references: [id])
  Type_id               Int?
  lensType              LensTypeMaster?          @relation(fields: [Type_id], references: [id])
  coating_id            Int?
  coating               LensCoatingMaster?       @relation(fields: [coating_id], references: [id])
  dia_id                Int?
  dia                   LensDiaMaster?           @relation(fields: [dia_id], references: [id])
  fitting_id            Int?
  fitting               LensFittingMaster?       @relation(fields: [fitting_id], references: [id])
  tinting_id            Int?
  tinting               LensTintingMaster?       @relation(fields: [tinting_id], references: [id])
  
  // Physical Location
  location_id           Int?
  location              LocationMaster?          @relation(fields: [location_id], references: [id])
  tray_id               Int?
  tray                  TrayMaster?              @relation(fields: [tray_id], references: [id])
  
  // Quantity & Pricing
  quantity              Float                    @default(1) // 0.5 for single eye, 1 for pair
  costPrice             Float                    // Purchase/inward price
  sellingPrice          Float?                   // Retail price
  
  // Eye Specifications (if applicable)
  rightEye              Boolean                  @default(false)
  leftEye               Boolean                  @default(false)
  rightSpherical        String?
  rightCylindrical      String?
  rightAxis             String?
  rightAdd              String?
  leftSpherical         String?
  leftCylindrical       String?
  leftAxis              String?
  leftAdd               String?
  
  // Status & Dates
  status                InventoryItemStatus      @default(AVAILABLE)
  expiryDate            DateTime?                // If applicable
  manufactureDate       DateTime?                // Manufacturing date
  inwardDate            DateTime                 @default(now())
  
  // Source Information
  purchaseOrderId       Int?                     // If from PO
  purchaseOrder         PurchaseOrder?           @relation(fields: [purchaseOrderId], references: [id])
  vendorId              Int?                     // Source vendor
  vendor                Vendor?                  @relation(fields: [vendorId], references: [id])
  
  // Sale Information (when sold)
  saleOrderId           Int?                     // When reserved/sold
  saleOrder             SaleOrder?               @relation(fields: [saleOrderId], references: [id])
  reservedDate          DateTime?                // When reserved for sale
  soldDate              DateTime?                // When actually sold
  
  // Quality & Condition
  qualityGrade          String?                  // A, B, C grade
  notes                 String?                  // Any special notes
  
  // Audit Fields
  activeStatus          Boolean                  @default(true)
  deleteStatus          Boolean                  @default(false)
  createdAt             DateTime                 @default(now())
  createdBy             Int
  updatedAt             DateTime                 @updatedAt
  updatedBy             Int?
  createdByUser         User                     @relation("inventoryItemCreatedBy", fields: [createdBy], references: [id])
  updatedByUser         User?                    @relation("inventoryItemUpdatedBy", fields: [updatedBy], references: [id])
  
  // Relationship Tables
  transactions          InventoryTransaction[]   @relation("inventoryItemTransactions")
}

// Track all inventory movements/transactions
model InventoryTransaction {
  id                    Int                      @id @default(autoincrement())
  transactionNo         String                   @unique // Auto-generated: IT-2025-001
  type                  InventoryTransactionType
  
  // Item Details
  inventoryItemId       Int
  inventoryItem         InventoryItem            @relation("inventoryItemTransactions", fields: [inventoryItemId], references: [id])
  
  // Quantity Movement
  quantity              Float                    // Positive for inward, negative for outward
  balanceAfter          Float                    // Running balance after this transaction
  unitPrice             Float?                   // Price per unit for this transaction
  totalValue            Float?                   // quantity × unitPrice
  
  // Location Movement
  fromLocationId        Int?                     // Source location
  fromLocation          LocationMaster?          @relation("inventoryFromLocation", fields: [fromLocationId], references: [id])
  fromTrayId            Int?                     // Source tray
  fromTray              TrayMaster?              @relation("inventoryFromTray", fields: [fromTrayId], references: [id])
  
  toLocationId          Int?                     // Destination location
  toLocation            LocationMaster?          @relation("inventoryToLocation", fields: [toLocationId], references: [id])
  toTrayId              Int?                     // Destination tray
  toTray                TrayMaster?              @relation("inventoryToTray", fields: [toTrayId], references: [id])
  
  // Reference Documents
  purchaseOrderId       Int?                     // If from PO inward
  purchaseOrder         PurchaseOrder?           @relation("inventoryPOTransactions", fields: [purchaseOrderId], references: [id])
  saleOrderId           Int?                     // If from sale outward
  saleOrder             SaleOrder?               @relation("inventorySaleTransactions", fields: [saleOrderId], references: [id])
  vendorId              Int?                     // Related vendor
  vendor                Vendor?                  @relation("inventoryVendorTransactions", fields: [vendorId], references: [id])
  
  // Additional Info
  reason                String?                  // Reason for adjustment/transfer
  notes                 String?                  // Transaction notes
  batchNo               String?                  // Batch reference
  
  // Audit Fields
  transactionDate       DateTime                 @default(now())
  createdAt             DateTime                 @default(now())
  createdBy             Int
  updatedAt             DateTime                 @updatedAt
  updatedBy             Int?
  createdByUser         User                     @relation("inventoryTransactionCreatedBy", fields: [createdBy], references: [id])
  updatedByUser         User?                    @relation("inventoryTransactionUpdatedBy", fields: [updatedBy], references: [id])
}

// Stock summary for quick lookups (can be generated view or maintained table)
model InventoryStock {
  id                    Int                      @id @default(autoincrement())
  
  // Product Identification
  lens_id               Int
  lensProduct           LensProductMaster        @relation(fields: [lens_id], references: [id])
  category_id           Int?
  category              LensCategoryMaster?      @relation(fields: [category_id], references: [id])
  Type_id               Int?
  lensType              LensTypeMaster?          @relation(fields: [Type_id], references: [id])
  coating_id            Int?
  coating               LensCoatingMaster?       @relation(fields: [coating_id], references: [id])
  
  // Location
  location_id           Int?
  location              LocationMaster?          @relation(fields: [location_id], references: [id])
  tray_id               Int?
  tray                  TrayMaster?              @relation(fields: [tray_id], references: [id])
  
  // Stock Quantities
  totalStock            Float                    @default(0) // Total available stock
  reservedStock         Float                    @default(0) // Reserved for sale orders
  availableStock        Float                    @default(0) // Available for sale (total - reserved)
  damagedStock          Float                    @default(0) // Damaged stock
  
  // Pricing
  avgCostPrice          Float?                   // Average cost price
  lastCostPrice         Float?                   // Latest purchase price
  sellingPrice          Float?                   // Current selling price
  
  // Dates
  lastInwardDate        DateTime?                // Last stock inward date
  lastOutwardDate       DateTime?                // Last stock outward date
  
  // Audit Fields
  updatedAt             DateTime                 @updatedAt
  updatedBy             Int?
  updatedByUser         User?                    @relation("inventoryStockUpdatedBy", fields: [updatedBy], references: [id])
  
  @@unique([lens_id, category_id, Type_id, coating_id, location_id, tray_id])
}

// Inventory alerts and notifications
model InventoryAlert {
  id                    Int                      @id @default(autoincrement())
  alertType             String                   // LOW_STOCK, EXPIRY, DAMAGE, etc.
  
  // Product Details
  lens_id               Int?
  lensProduct           LensProductMaster?       @relation(fields: [lens_id], references: [id])
  location_id           Int?
  location              LocationMaster?          @relation(fields: [location_id], references: [id])
  
  // Alert Details
  currentStock          Float?                   // Current stock level
  thresholdLevel        Float?                   // Minimum threshold
  message               String                   // Alert message
  priority              String                   @default("MEDIUM") // HIGH, MEDIUM, LOW
  
  // Status
  isRead                Boolean                  @default(false)
  isResolved            Boolean                  @default(false)
  resolvedAt            DateTime?
  resolvedBy            Int?
  resolver              User?                    @relation("inventoryAlertResolver", fields: [resolvedBy], references: [id])
  
  // Audit Fields
  createdAt             DateTime                 @default(now())
  createdBy             Int?
  createdByUser         User?                    @relation("inventoryAlertCreatedBy", fields: [createdBy], references: [id])
}

// ============================================
// AUDIT LOG & ERROR LOG TABLES
// ============================================

model AuditLog {
  id           Int      @id @default(autoincrement())
  userId       Int?
  action       String // CREATE, UPDATE, DELETE, READ
  entity       String // Table/Model name (e.g., "SaleOrder", "Customer")
  entityId     Int? // ID of the affected record
  oldValues    Json? // Previous values (for UPDATE/DELETE)
  newValues    Json? // New values (for CREATE/UPDATE)
  changes      Json? // Specific field changes
  ipAddress    String?
  userAgent    String?
  method       String? // HTTP method (GET, POST, PUT, DELETE)
  endpoint     String? // API endpoint
  statusCode   Int? // HTTP status code
  success      Boolean  @default(true)
  errorMessage String?  @db.Text
  metadata     Json? // Additional context
  createdAt    DateTime @default(now())
  // Relationship
  user         User?    @relation("auditLogUser", fields: [userId], references: [id])
}

model ErrorLog {
  id            Int       @id @default(autoincrement())
  userId        Int?
  errorType     String // Type of error (e.g., "ValidationError", "DatabaseError")
  errorMessage  String    @db.Text
  errorStack    String?   @db.Text
  errorCode     String? // Custom error code
  statusCode    Int? // HTTP status code
  method        String? // HTTP method
  endpoint      String? // API endpoint
  requestBody   Json? // Request payload
  requestParams Json? // Query/path parameters
  ipAddress     String?
  userAgent     String?
  severity      String    @default("ERROR") // INFO, WARNING, ERROR, CRITICAL
  resolved      Boolean   @default(false)
  resolvedAt    DateTime?
  resolvedBy    Int?
  resolution    String?   @db.Text
  metadata      Json? // Additional error context
  createdAt     DateTime  @default(now())
  // Relationships
  user          User?     @relation("errorLogUser", fields: [userId], references: [id])
  resolver      User?     @relation("errorLogResolver", fields: [resolvedBy], references: [id])
}
